APP_NAME=智学方舟 API
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
# 可选：运行数据目录。默认 backend/runtime；测试会自动使用隔离目录。
# RUNTIME_DIR=F:/软件杯/backend/runtime
LLM_PROVIDER=mock
LLM_TIMEOUT_SECONDS=60

# 讯飞星火 OpenAI-compatible API
XFYUN_API_KEY=
XFYUN_BASE_URL=https://spark-api-open.xf-yun.com/v1
XFYUN_MODEL=generalv3.5

# 任意 OpenAI-compatible 服务
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# DeepSeek / Qwen
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 本地 Embedding；模型不可用时自动回退 Hashing
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
